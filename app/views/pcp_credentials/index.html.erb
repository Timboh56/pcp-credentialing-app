<div class="min-h-screen bg-gray-50">
  <nav class="bg-white border-b border-gray-200 shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">
      <div class="flex items-center gap-3">
        <div class="flex items-center justify-center w-9 h-9 bg-blue-600 rounded-lg">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
        </div>
        <span class="font-semibold text-gray-900">PCP Credentialing</span>
      </div>
      <div class="flex items-center gap-4">
        <%= link_to "Dashboard", authenticated_root_path, class: "text-sm text-gray-500 hover:text-gray-900" %>
        <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-sm font-medium text-gray-600 hover:text-gray-900 bg-gray-100 hover:bg-gray-200 px-3 py-1.5 rounded-lg transition" %>
      </div>
    </div>
  </nav>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Credential Applications</h1>
        <p class="text-gray-500 mt-1"><%= @credentials.count %> total</p>
      </div>
      <%= link_to "New Application", new_pcp_credential_path,
            class: "inline-flex items-center gap-2 px-4 py-2 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition" %>
    </div>

    <% if @credentials.empty? %>
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-12 text-center">
        <p class="text-gray-500 text-sm">No credential applications yet.</p>
        <%= link_to "Submit the first one", new_pcp_credential_path, class: "mt-2 inline-block text-sm font-medium text-blue-600 hover:underline" %>
      </div>
    <% else %>
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
        <table class="min-w-full divide-y divide-gray-200 text-sm">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-5 py-3 text-left font-semibold text-gray-600">Name</th>
              <th class="px-5 py-3 text-left font-semibold text-gray-600">NPI</th>
              <th class="px-5 py-3 text-left font-semibold text-gray-600">Specialty</th>
              <th class="px-5 py-3 text-left font-semibold text-gray-600">Status</th>
              <th class="px-5 py-3 text-left font-semibold text-gray-600">Expiration Alerts</th>
              <th class="px-5 py-3 text-left font-semibold text-gray-600">Submitted</th>
              <th class="px-5 py-3"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% @credentials.each do |cred| %>
              <tr class="hover:bg-gray-50 transition">
                <td class="px-5 py-3 font-medium text-gray-900"><%= cred.full_name.presence || "—" %></td>
                <td class="px-5 py-3 text-gray-600"><%= cred.npi.presence || "—" %></td>
                <td class="px-5 py-3 text-gray-600"><%= cred.speciality&.humanize&.titleize || "—" %></td>
                <td class="px-5 py-3">
                  <% status_colors = {
                    "pending" => "bg-yellow-100 text-yellow-800",
                    "submitted" => "bg-blue-100 text-blue-800",
                    "under_review" => "bg-purple-100 text-purple-800",
                    "approved" => "bg-green-100 text-green-800",
                    "denied" => "bg-red-100 text-red-800",
                    "expired" => "bg-gray-100 text-gray-600"
                  } %>
                  <% if cred.status %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= status_colors[cred.status] || 'bg-gray-100 text-gray-600' %>">
                      <%= cred.status.humanize %>
                    </span>
                  <% else %>
                    <span class="text-gray-400">—</span>
                  <% end %>
                </td>
                <td class="px-5 py-3">
                  <% cred.expiration_statuses.each do |s| %>
                    <% badge = { expired: "bg-red-100 text-red-700", expires_soon: "bg-red-50 text-red-600", renew_soon: "bg-yellow-100 text-yellow-800" }[s[:status]] %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium mr-1 mb-1 <%= badge %>">
                      <%= s[:label] %>
                    </span>
                  <% end %>
                  <% if cred.expiration_statuses.empty? %>
                    <span class="text-gray-300">—</span>
                  <% end %>
                </td>
                <td class="px-5 py-3 text-gray-500"><%= cred.created_at.strftime("%b %-d, %Y") %></td>
                <td class="px-5 py-3 text-right">
                  <div class="flex items-center justify-end gap-3">
                    <%= link_to "View", cred, class: "text-blue-600 hover:underline" %>
                    <%= link_to "Edit", edit_pcp_credential_path(cred), class: "text-gray-600 hover:underline" %>
                    <%= button_to "Delete", cred, method: :delete,
                          data: { turbo_confirm: "Delete this credential application?" },
                          class: "text-red-500 hover:underline bg-transparent border-0 p-0 cursor-pointer text-sm" %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </main>
</div>
