  <%# ════════════════════════════════════════════════════════════ %>
  <%# 5. PCP Group %>
  <%# ════════════════════════════════════════════════════════════ %>
  <div class="<%= section_cls %>">
    <h2 class="<%= heading_cls %>">PCP Group</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <%= f.label :pcp_group_npi, "Group NPI", class: label_cls %>
        <%= f.text_field :pcp_group_npi, class: input_cls %>
      </div>
      <div>
        <%= f.label :pcp_group_tax_id, "Group Tax ID", class: label_cls %>
        <%= f.text_field :pcp_group_tax_id, class: input_cls %>
      </div>
      <div>
        <%= f.label :pcp_group_billing_address, "Billing Address", class: label_cls %>
        <%= f.text_field :pcp_group_billing_address, class: input_cls %>
      </div>
      <div>
        <%= f.label :pcp_group_billing_phone, "Billing Phone", class: label_cls %>
        <%= f.telephone_field :pcp_group_billing_phone, placeholder: "(555) 000-0000", class: input_cls %>
      </div>
    </div>
  </div>

  <%# ════════════════════════════════════════════════════════════ %>
  <%# 6. Documents %>
  <%# ════════════════════════════════════════════════════════════ %>
  <div class="<%= section_cls %>">
    <h2 class="<%= heading_cls %>">Documents</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      <div>
        <%= f.label :document_1, "Document 1", class: label_cls %>
        <%= f.text_field :document_1, class: input_cls %>
      </div>
      <div>
        <%= f.label :document_2, "Document 2", class: label_cls %>
        <%= f.text_field :document_2, class: input_cls %>
      </div>
      <div>
        <%= f.label :document_3, "Document 3", class: label_cls %>
        <%= f.text_field :document_3, class: input_cls %>
      </div>
      <div>
        <%= f.label :cv, "CV", class: label_cls %>
        <%= f.text_field :cv, class: input_cls %>
      </div>
      <div>
        <%= f.label :additional_document, "Additional Document", class: label_cls %>
        <%= f.text_field :additional_document, class: input_cls %>
      </div>
    </div>
  </div>

  <%# ════════════════════════════════════════════════════════════ %>
  <%# 7. Status %>
  <%# ════════════════════════════════════════════════════════════ %>
  <div class="<%= section_cls %>">
    <h2 class="<%= heading_cls %>">Status</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">

      <div>
        <%= f.label :status, class: label_cls %>
        <div class="relative custom-select">
          <%= raw list_svg %>
          <%= f.select :status,
                PcpCredential.statuses.keys.map { |k| [k.humanize, k] },
                { include_blank: "Select status…" },
                class: select_cls %>
          <%= raw chevron_svg %>
        </div>
      </div>

      <div>
        <%= f.label :approval_date, class: label_cls %>
        <div class="relative">
          <%= raw cal_svg %>
          <%= f.text_field :approval_date,
                value: credential.approval_date&.strftime("%Y-%m-%d"),
                placeholder: "YYYY-MM-DD",
                data: { datepicker: true },
                class: date_cls %>
          <%= raw chevron_svg %>
        </div>
      </div>

      <div class="flex flex-col gap-3 pt-1">
        <label class="flex items-center gap-3 cursor-pointer">
          <%= f.check_box :approved,
                class: "h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500 cursor-pointer" %>
          <span class="text-sm font-medium text-gray-700">Approved</span>
        </label>
        <label class="flex items-center gap-3 cursor-pointer">
          <%= f.check_box :receipt_confirmed,
                class: "h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500 cursor-pointer" %>
          <span class="text-sm font-medium text-gray-700">Receipt Confirmed</span>
        </label>
      </div>

    </div>
  </div>

<% end %>

<%# ── Work History Modal ──────────────────────────────────────── %>
<div id="wh-modal"
     class="hidden fixed inset-0 z-50 flex items-center justify-center px-4"
     style="background-color: rgba(0,0,0,0.5)">
  <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md p-6">
    <h3 class="text-base font-semibold text-gray-900 mb-5">Add Work History</h3>

    <div class="space-y-4">
      <div>
        <label class="<%= label_cls %>" for="wh-employer">Employer</label>
        <input type="text" id="wh-employer" placeholder="Hospital / Clinic name"
               class="<%= input_cls %>">
      </div>
      <div>
        <label class="<%= label_cls %>" for="wh-position">Position</label>
        <input type="text" id="wh-position" placeholder="e.g. Attending Physician"
               class="<%= input_cls %>">
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="<%= label_cls %>" for="wh-work-start">Work Start</label>
          <div class="relative">
            <%= raw cal_svg %>
            <input type="text" id="wh-work-start" placeholder="YYYY-MM-DD"
                   data-datepicker="true"
                   class="<%= date_cls %>">
            <%= raw chevron_svg %>
          </div>
        </div>
        <div>
          <label class="<%= label_cls %>" for="wh-work-end">Work End</label>
          <div class="relative">
            <%= raw cal_svg %>
            <input type="text" id="wh-work-end" placeholder="YYYY-MM-DD"
                   data-datepicker="true"
                   class="<%= date_cls %>">
            <%= raw chevron_svg %>
          </div>
        </div>
      </div>
    </div>

    <div class="flex items-center justify-end gap-3 mt-6">
      <button type="button" id="wh-modal-cancel"
              class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition">
        Cancel
      </button>
      <button type="button" id="wh-modal-save"
              class="px-5 py-2 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition shadow-sm">
        Save work history
      </button>
    </div>
  </div>
</div>

<%# ── Fixed bottom action bar ──────────────────────────────────── %>
<div class="fixed bottom-0 left-0 right-0 z-40 bg-white border-t border-gray-200 shadow-[0_-4px_16px_rgba(0,0,0,0.06)]">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-3 flex items-center justify-end gap-3">
    <%= link_to "Cancel", pcp_credentials_path,
          class: "px-5 py-2.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition" %>
    <button type="submit" form="pcp-credential-form" id="form-submit-btn"
            disabled
            class="px-6 py-2.5 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition shadow-sm cursor-pointer"
            style="opacity:0.4;cursor:not-allowed">
      Submit
    </button>
  </div>
</div>

<script>
(function () {
  // ── Submit button enabled/disabled ──────────────────────────
  var form      = document.getElementById("pcp-credential-form");
  var submitBtn = document.getElementById("form-submit-btn");

  function updateSubmitState() {
    if (!form || !submitBtn) return;
    var required  = form.querySelectorAll("[required]");
    var allFilled = Array.from(required).every(function (el) {
      return el.value.trim() !== "";
    });
    submitBtn.disabled          = !allFilled;
    submitBtn.style.opacity     = allFilled ? "" : "0.4";
    submitBtn.style.cursor      = allFilled ? "" : "not-allowed";
  }

  if (form && submitBtn) {
    updateSubmitState();
    form.addEventListener("input",  updateSubmitState);
    form.addEventListener("change", updateSubmitState);
  }

  // ── Work history ─────────────────────────────────────────────
  var whCounter = <%= credential.work_histories.count %>;
  var modal     = document.getElementById("wh-modal");
  var whList    = document.getElementById("work-history-list");
  var noWhMsg   = document.getElementById("no-wh-msg");

  function openModal() {
    modal.classList.remove("hidden");
    // Initialise flatpickr on modal date inputs if not already attached
    ["wh-work-start", "wh-work-end"].forEach(function (id) {
      var el = document.getElementById(id);
      if (el && !el._flatpickr && typeof flatpickr !== "undefined") {
        flatpickr(el, { dateFormat: "Y-m-d", allowInput: true });
      }
    });
  }

  function closeModal() {
    modal.classList.add("hidden");
    ["wh-employer", "wh-position", "wh-work-start", "wh-work-end"].forEach(function (id) {
      var el = document.getElementById(id);
      if (el) {
        if (el._flatpickr) el._flatpickr.clear();
        else el.value = "";
      }
    });
  }

  function updateNoWhMsg() {
    if (!whList || !noWhMsg) return;
    var visible = whList.querySelectorAll(".work-history-card:not(.hidden)");
    noWhMsg.classList.toggle("hidden", visible.length > 0);
  }

  var addBtn = document.getElementById("add-work-history-btn");
  if (addBtn) addBtn.addEventListener("click", openModal);

  var cancelBtn = document.getElementById("wh-modal-cancel");
  if (cancelBtn) cancelBtn.addEventListener("click", closeModal);

  if (modal) {
    modal.addEventListener("click", function (e) {
      if (e.target === modal) closeModal();
    });
  }

  var saveBtn = document.getElementById("wh-modal-save");
  if (saveBtn) {
    saveBtn.addEventListener("click", function () {
      var employer  = (document.getElementById("wh-employer").value  || "").trim();
      var position  = (document.getElementById("wh-position").value  || "").trim();
      var workStart = (document.getElementById("wh-work-start").value || "").trim();
      var workEnd   = (document.getElementById("wh-work-end").value   || "").trim();

      if (!employer || !position || !workStart) {
        alert("Employer, Position, and Work Start are required.");
        return;
      }

      var idx    = whCounter++;
      var cardId = "wh-new-" + idx;
      var prefix = "pcp_credential[work_histories_attributes][" + idx + "]";

      function mkHidden(name, value) {
        var inp = document.createElement("input");
        inp.type  = "hidden";
        inp.name  = name;
        inp.value = value;
        return inp;
      }

      var card = document.createElement("div");
      card.className = "work-history-card flex items-center gap-4 px-4 py-3 bg-gray-50 rounded-lg border border-gray-200";
      card.id = cardId;

      card.appendChild(mkHidden(prefix + "[employer]",   employer));
      card.appendChild(mkHidden(prefix + "[position]",   position));
      card.appendChild(mkHidden(prefix + "[work_start]", workStart));
      card.appendChild(mkHidden(prefix + "[work_end]",   workEnd));

      var info = document.createElement("div");
      info.className = "flex-1 min-w-0";

      var title = document.createElement("p");
      title.className = "text-sm font-semibold text-gray-900 truncate";
      title.textContent = employer + " \u2014 " + position;

      var dates = document.createElement("p");
      dates.className = "text-xs text-gray-500 mt-0.5";
      dates.textContent = workStart + " \u2013 " + (workEnd || "Present");

      info.appendChild(title);
      info.appendChild(dates);
      card.appendChild(info);

      var delBtn = document.createElement("button");
      delBtn.type = "button";
      delBtn.className = "delete-new-wh flex-shrink-0 text-sm font-medium text-red-600 hover:text-red-700 transition";
      delBtn.setAttribute("data-card-id", cardId);
      delBtn.textContent = "Delete";
      card.appendChild(delBtn);

      whList.appendChild(card);
      updateNoWhMsg();
      closeModal();
    });
  }

  // Delegated delete handlers
  document.addEventListener("click", function (e) {
    if (e.target.classList.contains("delete-new-wh")) {
      var card = document.getElementById(e.target.getAttribute("data-card-id"));
      if (card) card.remove();
      updateNoWhMsg();
    }
    if (e.target.classList.contains("delete-existing-wh")) {
      var card = document.getElementById(e.target.getAttribute("data-card-id"));
      if (card) {
        card.querySelector(".wh-destroy-field").value = "1";
        card.classList.add("hidden");
      }
      updateNoWhMsg();
    }
  });
})();
</script>
