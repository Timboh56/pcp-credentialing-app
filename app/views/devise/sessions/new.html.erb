<%# Full-screen purple→teal gradient background %>
<div class="min-h-screen flex items-center justify-center px-4"
     style="background: linear-gradient(135deg, #43c6f7 0%, #a855f7 50%, #ec4899 100%);">

  <%# White card %>
  <div class="w-full max-w-md bg-white rounded-2xl shadow-2xl px-12 py-14">

    <h1 class="text-4xl font-black text-center text-gray-900 mb-10 tracking-tight">Login</h1>

    <%= render "devise/shared/error_messages", resource: resource %>

    <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

      <%# Email field %>
      <div class="mb-8">
        <%= f.label :email, "Username", class: "block text-sm font-semibold text-gray-700 mb-3" %>
        <div class="flex items-center border-b border-gray-300 focus-within:border-purple-500 transition-colors pb-2">
          <svg class="w-5 h-5 text-gray-400 mr-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                  d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
          <%= f.input_field :email,
              type: "email",
              autofocus: true,
              autocomplete: "email",
              placeholder: "Type your username",
              class: "flex-1 bg-transparent text-gray-700 placeholder-gray-400 text-sm focus:outline-none" %>
        </div>
      </div>

      <%# Password field %>
      <div class="mb-3">
        <%= f.label :password, class: "block text-sm font-semibold text-gray-700 mb-3" %>
        <div class="flex items-center border-b border-gray-300 focus-within:border-purple-500 transition-colors pb-2">
          <svg class="w-5 h-5 text-gray-400 mr-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                  d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
          </svg>
          <%= f.input_field :password,
              type: "password",
              autocomplete: "current-password",
              placeholder: "Type your password",
              class: "flex-1 bg-transparent text-gray-700 placeholder-gray-400 text-sm focus:outline-none" %>
        </div>
      </div>

      <%# Forgot password %>
      <% if devise_mapping.recoverable? %>
        <div class="text-right mb-8">
          <%= link_to "Forgot password?",
              new_password_path(resource_name),
              class: "text-sm text-gray-500 hover:text-purple-600 transition-colors" %>
        </div>
      <% end %>

      <%# Login button — cyan→pink gradient pill %>
      <%= f.button :submit, "LOGIN",
          class: "w-full py-3.5 rounded-full text-white text-sm font-bold tracking-widest shadow-lg cursor-pointer transition hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500",
          style: "background: linear-gradient(to right, #43c6f7, #ec4899);" %>

    <% end %>

    <%# Divider %>
    <p class="text-center text-sm text-gray-400 mt-8 mb-4">Or Sign Up Using</p>

    <%# Social icons %>
    <div class="flex justify-center gap-4 mb-8">
      <%# Facebook %>
      <a href="#" class="w-12 h-12 rounded-full flex items-center justify-center text-white shadow-md hover:opacity-90 transition"
         style="background-color: #3b5998;">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
        </svg>
      </a>
      <%# Twitter / X %>
      <a href="#" class="w-12 h-12 rounded-full flex items-center justify-center text-white shadow-md hover:opacity-90 transition"
         style="background-color: #1da1f2;">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z"/>
        </svg>
      </a>
      <%# Google %>
      <a href="#" class="w-12 h-12 rounded-full flex items-center justify-center text-white shadow-md hover:opacity-90 transition"
         style="background-color: #db4437;">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M21.35 11.1H12.18V13.83H18.69C18.36 17.64 15.19 19.27 12.19 19.27C8.36 19.27 5 16.25 5 12C5 7.9 8.2 4.73 12.2 4.73C15.29 4.73 17.1 6.7 17.1 6.7L19 4.72C19 4.72 16.56 2 12.1 2C6.42 2 2.03 6.8 2.03 12C2.03 17.05 6.16 22 12.25 22C17.6 22 21.5 18.33 21.5 12.91C21.5 11.76 21.35 11.1 21.35 11.1Z"/>
        </svg>
      </a>
    </div>

    <% if devise_mapping.registerable? %>
      <p class="text-center text-sm text-gray-400 mb-2">Or Sign Up Using</p>
      <p class="text-center">
        <%= link_to "SIGN UP", new_registration_path(resource_name),
            class: "text-sm font-bold text-gray-700 hover:text-purple-600 tracking-widest transition-colors" %>
      </p>
    <% end %>

  </div>
</div>
