<div class="min-h-screen bg-gray-50 flex flex-col items-center justify-center px-4">

  <%# Logo %>
  <div class="flex items-center gap-2.5 mb-8">
    <div class="flex items-center justify-center w-10 h-10 bg-blue-600 rounded-xl shadow-md">
      <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
      </svg>
    </div>
    <span class="text-lg font-bold text-gray-900 tracking-tight">PCP Credentialing</span>
  </div>

  <%# Card %>
  <div class="w-full max-w-sm bg-white rounded-2xl border border-gray-200 shadow-lg p-8">

    <%# Icon %>
    <div class="flex items-center justify-center w-14 h-14 bg-blue-50 rounded-2xl mx-auto mb-5">
      <svg class="w-7 h-7 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
      </svg>
    </div>

    <h1 class="text-xl font-bold text-gray-900 text-center mb-1">Check your email</h1>
    <p class="text-sm text-gray-500 text-center mb-6">
      We sent a 6-digit code to<br>
      <span class="font-medium text-gray-700"><%= current_user.email %></span>
    </p>

    <%# Flash alerts %>
    <% if flash[:alert].present? %>
      <div class="mb-4 px-4 py-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700">
        <%= flash[:alert] %>
      </div>
    <% end %>
    <% if flash[:notice].present? %>
      <div class="mb-4 px-4 py-3 bg-green-50 border border-green-200 rounded-lg text-sm text-green-700">
        <%= flash[:notice] %>
      </div>
    <% end %>

    <%# OTP form %>
    <%= form_with url: verify_two_factor_path, method: :post do |f| %>
      <div class="mb-5">
        <%= f.label :otp_code, "Verification code", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.text_field :otp_code,
              autofocus: true,
              autocomplete: "one-time-code",
              inputmode: "numeric",
              maxlength: 6,
              placeholder: "000000",
              class: "w-full rounded-xl border border-gray-300 bg-white px-4 py-3 text-2xl font-bold text-center tracking-widest text-gray-900 placeholder-gray-300 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition" %>
        <p class="mt-1.5 text-xs text-gray-400">Code expires in 10 minutes</p>
      </div>

      <%= f.submit "Verify identity",
            class: "w-full px-4 py-3 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 rounded-xl transition shadow-sm cursor-pointer" %>
    <% end %>

    <%# Resend & sign out %>
    <div class="mt-5 flex items-center justify-between text-sm">
      <%= button_to "Resend code", resend_two_factor_path, method: :post,
            class: "text-blue-600 hover:underline font-medium bg-transparent border-0 cursor-pointer p-0" %>
      <%= button_to "Sign out", destroy_user_session_path, method: :delete,
            class: "text-gray-400 hover:text-gray-600 bg-transparent border-0 cursor-pointer p-0" %>
    </div>
  </div>

</div>
